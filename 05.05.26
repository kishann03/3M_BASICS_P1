CODE 4
--------------------------------------------------
#include<iostream>
#include<math.h>
using namespace std;
int main(){
    int n;
    cout<<"enter number of rows:";
    cin>>n;
    for(int i =1 ; i<=n ; i++ ){
        for(int j = i ; j>=1 ; j--){
            cout<<j<<" ";
        }
        cout<<endl;
    }
    return 0;
}

OUTPUT------------------
enter number of rows:5
1 
2 1 
3 2 1 
4 3 2 1 
5 4 3 2 1 


--------------------------------------------------
CODE 5 
--------------------------------------------------
#include<iostream>
#include<math.h>
using namespace std;
int main()
{
    int n;
    cout<<"enter number of rows:";
    cin>>n;
    for(int i = 1; i<=n ; i++){
        for(int j=i ; j>=1 ; j--){ 
            cout<<j%2<<" ";
        }
        cout<<endl;
    }
    return 0;
}

OUTPUT------------------
enter number of rows:5
1 
0 1 
1 0 1 
0 1 0 1 
1 0 1 0 1 
